# PostgreSQL (primary cloud database)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=lako
DATABASE_PASSWORD=lako
DATABASE_NAME=lako_pos

# SQLite offline database (local queue + offline store)
SQLITE_PATH=./data/lako-offline.sqlite

# API
API_PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DEFAULT_OWNER_USERNAME=owner
DEFAULT_OWNER_PASSWORD=lako-owner
DEFAULT_MANAGER_PIN=1234
QR_PAYMENT_TIMEOUT_SECONDS=300

# Payment provider credentials intentionally left empty until merchant accounts are configured
GCASH_MERCHANT_ID=
GCASH_MERCHANT_KEY=
GCASH_WEBHOOK_SECRET=
PAYMAYA_MERCHANT_ID=
PAYMAYA_MERCHANT_KEY=
PAYMAYA_WEBHOOK_SECRET=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001
